<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="@color/brand_purple"
            android:layout_marginBottom="24dp"
            android:contentDescription="Forgot Password Icon"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Şifremi Unuttum"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim."
            android:textColor="@color/text_sub"
            android:gravity="center"
            android:layout_marginBottom="40dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <EditText
                    android:id="@+id/etForgotEmail"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="E-posta Adresiniz"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/gradient_background"
                    android:backgroundTint="@color/input_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="24dp"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="10dp"
                    android:autofillHints="emailAddress"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnResetPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="BAĞLANTIYI GÖNDER"
                    android:textColor="@color/white"
                    android:background="@drawable/gradient_background"
                    android:backgroundTint="@color/brand_purple"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Giriş Ekranına Dön"
            android:textColor="@color/brand_blue"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:padding="12dp"
            android:textStyle="bold"/>

    </LinearLayout>

</RelativeLayout>