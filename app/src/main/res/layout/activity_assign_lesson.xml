<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/brand_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ders Atama"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_main"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ders Bilgileri"
                        android:textStyle="bold"
                        android:textColor="@color/brand_blue"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etLessonName"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Ders Adı"
                        android:background="@drawable/gradient_background"
                        android:backgroundTint="@color/input_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"
                        android:textSize="15sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sorumlu Hoca"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:layout_marginBottom="4dp"/>

                    <Spinner
                        android:id="@+id/spinnerTeachers"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/gradient_background"
                        android:backgroundTint="@color/input_bg"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Devam Zorunluluğu (%)"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etMinAttendance"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:hint="Örn: 70"
                        android:inputType="number"
                        android:background="@drawable/gradient_background"
                        android:backgroundTint="@color/input_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"
                        android:textSize="15sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Öğrenci ID'leri (Virgülle ayırın)"
                        android:textSize="12sp"
                        android:textColor="@color/text_sub"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etStudentIds"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="170423825, 170423826..."
                        android:inputType="textMultiLine"
                        android:lines="4"
                        android:gravity="top"
                        android:background="@drawable/gradient_background"
                        android:backgroundTint="@color/input_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="24dp"
                        android:textSize="14sp"/>

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSaveAssignment"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ATAMAYI KAYDET"
                        android:textColor="@color/white"
                        android:background="@drawable/gradient_background"
                        android:backgroundTint="@color/brand_blue"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>